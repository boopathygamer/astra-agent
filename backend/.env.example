# ──────────────────────────────────────────────
# Universal AI Agent — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# The system auto-detects available providers from these keys.
# If no API key is set, the local Mistral 7B model is used.

# ── Provider Selection ──
# Options: auto | gemini | claude | chatgpt | local
# "auto" picks the first available API provider
LLM_PROVIDER=auto

# ── Google Gemini ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic Claude ──
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OpenAI ChatGPT ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Server ──
LLM_API_HOST=127.0.0.1
LLM_API_PORT=8000

# ── CORS ──
# Comma-separated list of allowed frontend origins.
# Defaults include Vite dev server (5173), backend self-serve (8000), and legacy port (3000).
LLM_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8000
