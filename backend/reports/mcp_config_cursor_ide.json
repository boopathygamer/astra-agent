{
  "mcpServers": {
    "astra-agent": {
      "command": "python",
      "args": [
        "-m",
        "mcp_server"
      ],
      "cwd": "c:\\astra agent\\backend",
      "env": {
        "LLM_PROVIDER": "auto",
        "PYTHONIOENCODING": "utf-8"
      }
    },
    "astra-agent-http": {
      "url": "http://127.0.0.1:8080/mcp",
      "transport": "streamable-http",
      "description": "Astra Agent MCP via HTTP (use when stdio is unavailable)"
    }
  }
}
